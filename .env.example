# ─────────────────────────────────────────────────────────────
# Perp Screener — переменные окружения
# Скопируйте в .env и заполните. Для публичных данных Binance
# API-ключи НЕ нужны — они опциональны (нужны только для приватных эндпоинтов).
# ─────────────────────────────────────────────────────────────

# --- PostgreSQL / TimescaleDB ---
POSTGRES_USER=screener
POSTGRES_PASSWORD=screener_pwd
POSTGRES_DB=screener
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
# Полный DSN (используется сервисами). Если меняете значения выше — синхронизируйте.
DATABASE_URL=postgresql://screener:screener_pwd@timescaledb:5432/screener

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# --- Binance ---
# Публичные данные не требуют ключей. Заполните, только если будете
# обращаться к приватным эндпоинтам (баланс, ордера) — на проде НЕ нужно.
BINANCE_API_KEY=
BINANCE_API_SECRET=
# fapi = USDⓈ-M futures (perpetuals). Менять не нужно.
BINANCE_FUTURES_REST=https://fapi.binance.com
BINANCE_FUTURES_WS=wss://fstream.binance.com/stream

# --- Ингест ---
# Сколько топовых перпов по объёму отслеживать.
SCREENER_SYMBOL_LIMIT=40
# Жёсткий вайтлист (через запятую). Если пусто — берём топ-N по объёму автоматически.
SCREENER_SYMBOLS=
# Глубина бэкофилла истории при старте (дней 1m-свечей).
BACKFILL_DAYS=7
# Таймфрейм сырых свечей.
BASE_TIMEFRAME=1m

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# CORS origin фронтенда.
FRONTEND_ORIGIN=http://localhost:5173

# --- Frontend ---
VITE_API_BASE=http://localhost:8000
VITE_WS_BASE=ws://localhost:8000
